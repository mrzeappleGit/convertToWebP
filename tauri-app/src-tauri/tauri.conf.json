{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WebWeaverKit",
  "version": "1.12.0",
  "identifier": "com.matthewstevens.webweaverkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Web Weaver Kit",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../resources/ffmpeg.exe": "resources/ffmpeg.exe",
      "../../resources/cjpegli.exe": "resources/cjpegli.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
